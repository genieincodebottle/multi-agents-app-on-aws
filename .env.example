# ===========================================================================
# Multi-Agent App Configuration
# Copy this to .env and fill in your values
# ===========================================================================

# AWS Region (models must be enabled in this region)
AWS_REGION=us-east-1

# Bedrock Model (change to Nova Lite for cheaper testing)
# Options: us.anthropic.claude-sonnet-4-20250514, us.amazon.nova-lite-v1:0, us.amazon.nova-pro-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# Web Search (optional - get free key at https://tavily.com)
# Without this, agents use mock search results for testing
TAVILY_API_KEY=

# Logging
LOG_LEVEL=INFO

# Agent limits
MAX_RESEARCH_RESULTS=5
MAX_AGENT_ITERATIONS=10

# AgentCore Memory (auto-created during deployment, leave empty for local)
AGENTCORE_MEMORY_ID=
