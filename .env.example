# ===========================================================================
# Multi-Agent App Configuration
# Copy this to .env and fill in your values
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM Provider (pick ONE: groq, gemini, or bedrock)
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq

# --- Option 1: Groq (FREE - recommended to start) ---
# Get your free API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.3-70b-versatile
# Other Groq models: llama-3.1-8b-instant, gemma2-9b-it, mixtral-8x7b-32768

# --- Option 2: Gemini (FREE - https://aistudio.google.com/apikey) ---
# LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.0-flash
# Other Gemini models: gemini-2.5-flash, gemini-2.5-pro

# --- Option 3: AWS Bedrock (best quality, pay-per-use) ---
# LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# Other Bedrock models: us.amazon.nova-lite-v1:0, us.amazon.nova-pro-v1:0

# ---------------------------------------------------------------------------
# Web Search (optional - get free key at https://tavily.com)
# Without this, agents use mock search results for testing
# ---------------------------------------------------------------------------
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# General settings
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
MAX_RESEARCH_RESULTS=5
MAX_AGENT_ITERATIONS=10

# AgentCore Memory (auto-created during deployment, leave empty for local)
AGENTCORE_MEMORY_ID=
